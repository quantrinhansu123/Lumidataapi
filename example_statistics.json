{
  "examples": {
    "example_1_post_statistics": {
      "method": "POST",
      "url": "http://127.0.0.1:8000/orders/statistics",
      "body": {
        "filters": {
          "team": ["Team A", "Team B"],
          "delivery_status": "Delivered",
          "country": "US"
        },
        "date_range": {
          "from": "01/03/2026",
          "to": "31/03/2026"
        },
        "date_column": "created_at"
      },
      "description": "Tính toán thống kê với nhiều filter và date range"
    },
    "example_2_post_simple": {
      "method": "POST",
      "url": "http://127.0.0.1:8000/orders/statistics",
      "body": {
        "filters": {
          "delivery_status": "Delivered",
          "payment_status": "Paid"
        }
      },
      "description": "Tính toán thống kê với filter đơn giản"
    },
    "example_3_get_statistics": {
      "method": "GET",
      "url": "http://127.0.0.1:8000/orders/statistics?created_at=01/03/2026&team=Team%20A",
      "description": "Tính toán thống kê qua query params"
    },
    "example_4_get_with_multiple_filters": {
      "method": "GET",
      "url": "http://127.0.0.1:8000/orders/statistics?created_at=01/03/2026&delivery_status=Delivered&payment_status=Paid&country=US",
      "description": "Tính toán thống kê với nhiều filter qua query params"
    }
  },
